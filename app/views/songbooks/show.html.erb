<h1><%= @songbook.name %> has <%= number_with_delimiter(@songbook.songs.count, delimiter: ',') %> songs</h1>

<div class="row">
  <div class="span12">
    <table id="songbook-table" class="table table-striped table-bordered" cellspacing="0" width="100%">
      <thead>
        <tr><th>Artist</th><th>Title</th><th>Brand</th></tr>
      </thead>
    </table>
  </div>
</div>

<script>
  $(function() {
    if (!$.fn.DataTable.isDataTable("#songbook-table")) {
      $("#songbook-table").DataTable({
        pageLength: 100,
        data: <%= raw @songs.map { |s| { artist: s.artist, title: s.title, brand: s.brand } }.to_json %>,
        columns: [{ data: "artist" }, { data: "title" }, { data: "brand" }]
      });
    }
  });
</script>

